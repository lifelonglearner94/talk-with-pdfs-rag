##########
# Example environment configuration for talk-with-pdfs
# Copy this file to `.env` and adjust values as needed. All variables are optional
# unless noted. Values here mirror defaults in code unless changed.
##########

# --- Core model + embedding settings ---
RAG_EMBEDDING_MODEL=models/text-embedding-004
RAG_LLM_MODEL=gemini-2.5-flash

## Retrieval defaults
RAG_TOP_K=10
RAG_RETRIEVAL_STRATEGY=similarity  # or mmr
RAG_MMR_LAMBDA_MULT=0.5
RAG_MMR_FETCH_K_FACTOR=4
RAG_MMR_MIN_FETCH_K=50

# Chunking
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200

# Directories
RAG_DATA_DIR=data
RAG_PERSIST_DIR=vectorstore

## Logging (INFO, DEBUG)
RAG_LOG_LEVEL=INFO
RAG_LOG_JSON=0  # set to 1 for JSON logs

# API keys (required for actual embedding + LLM calls)
# GOOGLE_API_KEY=your_key_here

# Embedding backoff tuning (advanced; rarely needed)
# RAG_EMBED_MAX_RETRIES=6
# RAG_EMBED_BASE_DELAY=0.5
# RAG_EMBED_BACKOFF_FACTOR=2.0
# RAG_EMBED_MAX_DELAY=30
# RAG_EMBED_BATCH_SIZE=32
# RAG_EMBED_REQUESTS_PER_MIN=60
# RAG_EMBED_LONG_QUOTA_PAUSE=60
